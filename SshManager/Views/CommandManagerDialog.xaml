<Window x:Class="SshManager.Views.CommandManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saved Commands"
        Width="600" Height="500"
        MinWidth="400" MinHeight="350"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <TextBox x:Name="SearchBox" Padding="6"
                     TextChanged="SearchBox_TextChanged"
                     VerticalContentAlignment="Center"/>
            <TextBlock Text="&#x1F50D; Search commands..." IsHitTestVisible="False"
                       Foreground="Gray" Padding="8,6,0,6" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Command list -->
        <ListBox x:Name="CommandList" Grid.Row="1"
                 HorizontalContentAlignment="Stretch"
                 MouseDoubleClick="CommandList_MouseDoubleClick"
                 BorderThickness="1" BorderBrush="#CCCCCC">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding Command}" FontFamily="Consolas" FontSize="11"
                                       Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="10" Opacity="0.4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Global (all servers)"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SessionId}" Value="{x:Null}">
                                                <Setter Property="Text" Value="Global (all servers)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Run" Padding="10,4"
                                VerticalAlignment="Center" Click="RunCommand_Click"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0"
                    HorizontalAlignment="Right">
            <Button Content="Add" Padding="10,6" Margin="0,0,4,0" Click="Add_Click"/>
            <Button Content="Edit" Padding="10,6" Margin="0,0,4,0" Click="Edit_Click"/>
            <Button Content="Delete" Padding="10,6" Margin="0,0,12,0" Click="Delete_Click"/>
            <Button Content="Close" Padding="10,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
