<Window x:Class="SshManager.Views.CommandEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Command"
        Width="460" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Padding="4" Margin="0,0,0,6"/>

        <!-- Command -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Command:" VerticalAlignment="Center" Margin="0,0,0,6"/>
        <TextBox x:Name="CommandBox" Grid.Row="1" Grid.Column="1" Padding="4" Margin="0,0,0,6"
                 FontFamily="Consolas" AcceptsReturn="False"/>

        <!-- Scope -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Scope:" VerticalAlignment="Center" Margin="0,0,0,6"/>
        <ComboBox x:Name="ScopeCombo" Grid.Row="2" Grid.Column="1" Padding="4" Margin="0,0,0,6"/>

        <!-- Notes -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Notes:" VerticalAlignment="Top" Margin="0,0,0,6"/>
        <TextBox x:Name="NotesBox" Grid.Row="3" Grid.Column="1" Padding="4" Margin="0,0,0,6"
                 AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save" Padding="12,6" Margin="0,0,6,0"
                    IsDefault="True" Click="Save_Click"/>
            <Button Content="Cancel" Padding="12,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
