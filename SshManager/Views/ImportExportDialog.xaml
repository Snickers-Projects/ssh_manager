<Window x:Class="SshManager.Views.ImportExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import / Export Sessions"
        Width="480" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Export section -->
        <GroupBox Grid.Row="0" Header="Export" Padding="8">
            <StackPanel>
                <TextBlock Text="Export all sessions and saved commands to a file." TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Format:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ExportFormatCombo" Grid.Column="1"
                              DisplayMemberPath="DisplayName" Padding="4"/>
                </Grid>
                <Button Content="Export..." Padding="12,6" Margin="0,8,0,0"
                        HorizontalAlignment="Left" Click="Export_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Import section -->
        <GroupBox Grid.Row="2" Header="Import" Padding="8">
            <StackPanel>
                <TextBlock Text="Import sessions and commands from a file. Duplicate sessions (same name + host) will be skipped."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Format:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ImportFormatCombo" Grid.Column="1"
                              DisplayMemberPath="DisplayName" Padding="4"/>
                </Grid>
                <Button Content="Import..." Padding="12,6" Margin="0,8,0,0"
                        HorizontalAlignment="Left" Click="Import_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="4" Foreground="Green"
                   TextWrapping="Wrap" Margin="0,8,0,0"/>

        <!-- Close -->
        <Button Grid.Row="4" Content="Close" Padding="12,6"
                HorizontalAlignment="Right" IsCancel="True" Click="Close_Click"/>
    </Grid>
</Window>
