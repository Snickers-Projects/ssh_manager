<Window x:Class="SshManager.Views.SessionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Session"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="16">

        <!-- Name -->
        <TextBlock Text="Session Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Padding="4" Margin="0,0,0,12"/>

        <!-- Host &amp; Port -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Host" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="HostBox" Padding="4"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Port" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="PortBox" Padding="4" Text="22"/>
            </StackPanel>
        </Grid>

        <!-- Username -->
        <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="UsernameBox" Padding="4" Margin="0,0,0,12"/>

        <!-- Auth Method -->
        <TextBlock Text="Authentication" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="AuthMethodBox" Padding="4" Margin="0,0,0,12"
                  SelectionChanged="AuthMethodBox_SelectionChanged">
            <ComboBoxItem Content="Password (saved)" Tag="Password"/>
            <ComboBoxItem Content="Password (prompt each time)" Tag="PromptPassword"/>
            <ComboBoxItem Content="Private Key" Tag="PrivateKey"/>
        </ComboBox>

        <!-- Password panel (visible when Password auth) -->
        <StackPanel x:Name="PasswordPanel" Margin="0,0,0,12">
            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Padding="4"/>
        </StackPanel>

        <!-- Private Key panel (visible when PrivateKey auth) -->
        <StackPanel x:Name="PrivateKeyPanel" Visibility="Collapsed" Margin="0,0,0,12">
            <TextBlock Text="Private Key Path" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PrivateKeyPathBox" Grid.Column="0" Padding="4"/>
                <Button Grid.Column="1" Content="Browse..." Margin="4,0,0,0" Padding="8,4"
                        Click="BrowsePrivateKey_Click"/>
            </Grid>
        </StackPanel>

        <!-- Group -->
        <TextBlock Text="Group (optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="GroupBox" Padding="4" Margin="0,0,0,12"/>

        <!-- Notes -->
        <TextBlock Text="Notes (optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="NotesBox" Padding="4" Margin="0,0,0,16"
                 AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- Save / Cancel -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Padding="20,6" Margin="0,0,8,0" IsDefault="True"
                    Click="Save_Click"/>
            <Button Content="Cancel" Padding="20,6" IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
